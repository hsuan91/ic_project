
module testbench;
  logic rst;
  logic clk;
  logic [31:0] regs_31;

  wire flash_so;
  logic flash_cs;
  logic flash_si;
  
  top u_top(
	  .rst      (rst      ),
	  .clk      (clk      ),

    .flash_so (flash_so ),
    .flash_si (flash_si ),
    .flash_cs (flash_cs ),
    //
    .regs_31  (regs_31  )
  );

  //========================
  // Flash
  //========================
  MX25L1006E u_flash (
      .SCLK (clk),          // clock
      .CS   (flash_cs),
      .SI   (flash_si),
      .SO   (flash_so),
      .WP   (1'b1),         // 1:common op
      .HOLD (1'b1)          // 1:common op
  );
  
  initial
  begin
    clk = 0;
    rst = 1;
    #40 rst = 0;
    #20000 $stop;
  end
  
  always #10 clk = ~clk;
endmodule